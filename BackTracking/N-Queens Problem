Problem:
he n-queens puzzle is the problem of placing n queens on a (n × n) chessboard such that no two queens can attack each other. Note that two queens attack each other if they are placed on the same row, the same column, or the same diagonal.

Given an integer n, find all distinct solutions to the n-queens puzzle.
You can return your answer in any order but each solution should represent a distinct board configuration of the queen placements, where the solutions are represented as permutations of [1, 2, 3, ..., n].

In this representation, the number in the ith position denotes the column in which the queen is placed in the ith row.
For eg. below figure represents a chessboard [2, 4, 1, 3].

Time complexity: O(n!)
Space complexity: o(n*n)


Code:
class Solution {
    public ArrayList<ArrayList<Integer>> nQueen(int n) {
        // code here
        
        ArrayList<ArrayList<Integer>> ans = new ArrayList<>();
        
         char[][] board = new char[n][n];
         
         for(char[] ch : board) {
             Arrays.fill(ch, '.');
         }
         
         
         f(0, board, new ArrayList<>(), ans);
         
         return ans;
        
        
    }
    
    private void f(int row, char[][] board, List<Integer> list, ArrayList<ArrayList<Integer>> ans) {
        
        if(row == board.length) {
            ans.add(new ArrayList<>(list));
            return;
        }
        
        
        for(int col = 0; col < board.length; col++) {
            if(isValid(row, col, board)) {
                board[row][col] = 'Q';
                list.add(col+1);
                f(row+1, board, list, ans);
                board[row][col] = '.';
                list.remove(list.size()-1);
            }
        }
    }
    
    private boolean isValid(int row, int col, char[][] board) {
        
        for(int i = row - 1; i >= 0; i--) {
            if(board[i][col] == 'Q') return false;
        }
        
        int rw = row-1;
        int cl = col-1;
        
        while(rw >= 0 && cl >= 0) {
            if(board[rw][cl] == 'Q') return false;
            
            rw--;
            cl--;
        }
        
        rw = row - 1;
        cl = col + 1;
        
        while(rw >= 0 && cl < board.length) {
            if(board[rw][cl] == 'Q') return false;
            rw--;
            cl++;
            
        }
        
        return true;
    }
}