Problem:
Given a string s, find all possible ways to partition it such that every substring in the partition is a palindrome.

Examples:

Input: s = "geeks"
Output: [[g, e, e, k, s], [g, ee, k, s]]
Explanation: [g, e, e, k, s] and [g, ee, k, s] are the only partitions of "geeks" where each substring is a palindrome.

Time complexity: O(n * 2^n)
Space complexity: (2^n)

Code:

Solution 1->
class Solution {
    public ArrayList<ArrayList<String>> palinParts(String s) {
        
        ArrayList<ArrayList<String>> ans = new ArrayList<>();
        
        f(0,1, s, new ArrayList<>(), ans);
        
        return ans;
    }
    
    private void f(int start, int end, String word, ArrayList<String> list, ArrayList<ArrayList<String>> ans) {
        
        if(start == word.length()) {
            ans.add(new ArrayList<>(list));
            return;
        }
        
        if(end > word.length()) return;
        
        if(isPalindrome(word.substring(start, end))){
            list.add(word.substring(start, end));
            f(end, end+1, word, list, ans);
            
            list.remove(list.size()-1);
        }
        
        f(start, end+1, word, list, ans);
    }
    
    private boolean isPalindrome(String word) {
        
        if(word.length() == 1) return true;
        
        int j = word.length()-1;
        int i = 0;
        while(i <= j) {
            if(word.charAt(i) != word.charAt(j)) {
                return false;
            }
            
            i++;
            j--;
            
        }
        
        return true;

    }
}

Solution 2 -> This solution will reduce the space complexity as it reduces the stack space.
class Solution {
    public ArrayList<ArrayList<String>> palinParts(String s) {
        
        ArrayList<ArrayList<String>> ans = new ArrayList<>();
        
        f(0, s, new ArrayList<>(), ans);
        
        return ans;
    }
    
    private void f(int start, String word, ArrayList<String> list, ArrayList<ArrayList<String>> ans) {
        
        if(start == word.length()) {
            ans.add(new ArrayList<>(list));
            return;
        }
        
        for(int i = start; i < word.length(); i++) {
            
            if(isPalindrome(word.substring(start, i+1))){
                list.add(word.substring(start, i+1));
                f(i+1, word, list, ans);
                list.remove(list.size()-1);
            }
            
        }
        
    }
    
    private boolean isPalindrome(String word) {
        
        if(word.length() == 1) return true;
        
        int j = word.length()-1;
        int i = 0;
        while(i <= j) {
            if(word.charAt(i) != word.charAt(j)) {
                return false;
            }
            
            i++;
            j--;
            
        }
        
        return true;

    }
}

