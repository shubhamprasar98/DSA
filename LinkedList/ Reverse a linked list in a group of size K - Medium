class Solution {
    public ListNode reverseKGroup(ListNode head, int k) {

        if(head == null || k <= 1){
            return head;
        }

        ListNode temp = head;

        ListNode prevNode = null;
        ListNode nextNode = null;

        while(temp != null){

            ListNode kthNode = getKthNode(temp, k);

            if(kthNode == null){
                if(prevNode != null){
                    prevNode.next = temp;
                }

                break;
            }

            nextNode = kthNode.next;
            kthNode.next = null;

            reverse(temp);

            if(temp == head){
                head = kthNode;
            }
            else{
                prevNode.next = kthNode;
            }

            prevNode = temp;
            temp = nextNode;

        }

        return head;

        
    }


    ListNode getKthNode(ListNode head, int k) {
        k--;
        while(head != null && k != 0){
            head = head.next;
            k--;
        }

        return head;
    }



    ListNode reverse(ListNode head){

        if(head == null || head.next == null){
            return head;
        }

        ListNode start = head;
        ListNode curr = head.next;
        head.next = null;

        while(curr != null){
            ListNode temp = curr;
            curr = curr.next;
            temp.next = start;
            start = temp;
        }

        return start;

    }
}