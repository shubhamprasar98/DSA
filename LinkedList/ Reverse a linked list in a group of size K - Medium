class Solution {
    public ListNode reverseKGroup(ListNode head, int k) {
        
        if(head == null || head.next == null || k == 1) return head;

        ListNode curr = head;
        ListNode prev = head;

        ListNode dummy = new ListNode();
        ListNode last = dummy;
    

        int cnt = 1;
        while(curr != null) {

            if(cnt == k) {
               
               ListNode next = curr.next;
               curr.next = null;

               curr = next;

               ListNode node = reverse(prev);

               last.next = node;
               last = prev;
               prev = next;

               cnt = 1;
               continue;
            }

            curr = curr.next;
            cnt++;

            
        }

        last.next = prev;

        return dummy.next;
        
    }

    ListNode reverse(ListNode head) {

        ListNode prev = null;
        ListNode curr = head;

        while(curr != null) {
            ListNode temp = curr.next;
            curr.next = prev;
            prev = curr;
            curr = temp;
        }

        return prev;
    }
}

