Approach: Floyd cycle detection

Time complexity: O(n)
Space complexity: O(1)
Code:
class Solution {
    public static void removeLoop(Node head) {
        
        if(head == null) return;
        
        Node slow = head;
        Node fast = head;
        Node prev = null;
        
        while(fast.next != null && fast.next.next != null) {
            
            slow = slow.next;
            prev = fast.next;
            fast = fast.next.next;
            
            if(slow == fast){
                break;
            }
            
        }
        
        if(slow == fast) {
        
            slow = head;
            
            if(slow == fast) {
                prev.next = null;
                return;
            }
            
            while(slow.next != fast.next) {
                slow = slow.next;
                fast = fast.next;
            }
            
            fast.next = null;
            
        }
    }
}