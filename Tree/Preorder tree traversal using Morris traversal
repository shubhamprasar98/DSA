class Solution {
    public ArrayList<Integer> preOrder(Node root) {
 
        ArrayList<Integer> ans = new ArrayList<>();
        
        Node curr = root;
        
        while(curr != null) {
            
            
            if(curr.left == null) {
                ans.add(curr.data);
                curr = curr.right;
            }
            
            else{
                Node prev = curr.left;
                
                while(prev.right != null && prev.right != curr) {
                    prev = prev.right;
                }
                
                if(prev.right == null) {
                    ans.add(curr.data);
                    prev.right = curr;
                    curr = curr.left;
                }
                else{
                    prev.right = null;
                    curr = curr.right;
                }
            }
        }
        return ans;
    }
}