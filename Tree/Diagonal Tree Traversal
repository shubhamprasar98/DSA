class Tree {
    public ArrayList<Integer> diagonal(Node root) {
        
        ArrayList<Integer> al = new ArrayList<>();
        
        Deque<Node> q = new LinkedList<>();
        
        q.offer(root);
        
        while(!q.isEmpty()) {
            Node node = q.poll();
            
            al.add(node.data);
            
            if(node.right != null) q.offerFirst(node.right);
            if(node.left != null) q.offer(node.left);
        }
        
        return al;
        
        
    }
}