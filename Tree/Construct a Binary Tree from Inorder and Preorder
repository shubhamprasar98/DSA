Time complexity: O(n^2) 
Space complexity: O(n)

Note: Use HashMap to find index which will reduce time complexity to -> O(n)

Code:
class Solution {
    public static Node buildTree(int inorder[], int preorder[]) {
        // code here
        
        if(inorder.length == 0) return null;
        
        return f(0, inorder.length-1, inorder, 0, preorder.length-1, preorder);
    }
    
    static Node f(int startin, int endin, int[] inorder, int startpre, int endpre, int[] preorder) {
        
        
        if(startin > endin) return null;
        
        Node node = new Node(preorder[startpre]);
        
        int index = findIndex(inorder, preorder[startpre]);
        int leftcount = index - startin;
        
        node.left = f(startin, index-1, inorder, startpre+1, startpre+leftcount, preorder);
        node.right = f(index+1, endin, inorder,startpre+leftcount+1, endpre, preorder);
        
        
        return node;
    }
    
    static int findIndex(int[] arr, int target){
        
        for(int i = 0; i < arr.length; i++) {
            if(target == arr[i]) return i;
        }
        
        return -1;
    }
}
